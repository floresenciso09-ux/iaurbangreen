# --- Local: copia este archivo a .env y rellena valores. Luego: npm run dev ---
# Puerto (por defecto 3000). La app Expo puede usar EXPO_PUBLIC_API_URL=http://TU_IP_LAN:3000
PORT=3000

DATABASE_URL=postgresql://user:pass@host:5432/dbname
JWT_SECRET=genera-un-secreto-largo

# Notas de planta (Gemini). Prueba: POST http://localhost:3000/plants/gemini-test  body: {"message":"hola"}
# GEMINI_API_KEY=tu_clave_de_aistudio_google
# GEMINI_MODEL=gemini-2.5-flash
# PLANT_INSIGHTS_PROVIDER=gemini

# Ollama (opcional): si defines OLLAMA_BASE_URL sin querer Gemini, revisa services/plantInsights.js
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3.2:3b
# URL pública del API (enlaces en el correo). Sin barra final.
# En Render puedes usar también la variable automática RENDER_EXTERNAL_URL.
PUBLIC_API_URL=https://urbangreen.onrender.com
# Resend (recomendado en producción). Si está definido, tiene prioridad sobre SMTP.
# RESEND_API_KEY=re_xxxxxxxx
# Remitente verificado en Resend (dominio o onboarding@resend.dev en pruebas)
# RESEND_FROM="UrbanGreen <onboarding@resend.dev>"
# SMTP (si no configuras RESEND_API_KEY ni SMTP_HOST, el enlace de activación se imprime en los logs)
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="UrbanGreen <noreply@tudominio.com>"
# OAuth Google — POST /auth/google. Obligatorio para login con Google desde la app.
# Debe ser el MISMO ID de cliente OAuth tipo "Web" que EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID en la app Expo.
# Sin esta variable el endpoint responde 501.
GOOGLE_WEB_CLIENT_ID=

# Zonas verdes: enriquecimiento opcional (fusiona con OSM tras cada fetch Overpass)
# GEOAPIFY_API_KEY=
# FOURSQUARE_API_KEY=
#
# Premium / IA avanzada — POST /billing/subscribe (sin STRIPE_SECRET_KEY activa 30 días en modo dev)
# STRIPE_SECRET_KEY=
# Cron monitor de sensores (Expo push). Desactivar: PLANT_MONITOR_DISABLED=true
# PLANT_MONITOR_CRON=0 */6 * * *
# PLANT_MONITOR_DISABLED=false

# Forzar datos nuevos (Overpass + externas) sin esperar TTL:
# GET  /green-zones/hermosillo?refresh=true
# POST /green-zones/hermosillo/intersections  body: { "polygon": [[lng,lat],...], "refresh": true }
#
# Borrar caché memoria + disco: npm run invalidate-green-zones-cache
