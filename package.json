{
  "name": "urbangreenbackend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "node -r dotenv/config server.js",
    "start": "node server.js",
    "simulate:sensor": "node -r dotenv/config scripts/simulate-sensor-data.js",
    "build:place-ids": "node scripts/build-park-google-place-ids.js --write",
